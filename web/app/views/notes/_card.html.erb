<%= link_to note_path(note), class: "block break-inside-avoid bg-white rounded-lg border border-gray-200 hover:shadow-lg transition-shadow duration-200 cursor-pointer group overflow-hidden", data: { turbo_frame: "_top" } do %>
  <div class="p-4">
    <% if note.title.present? %>
      <h3 class="font-medium text-gray-900 text-sm leading-snug mb-2 line-clamp-2"><%= note.title %></h3>
    <% end %>

    <% if note.body.present? %>
      <% if note.checklist? %>
        <div class="text-xs text-gray-600 leading-relaxed space-y-0.5">
          <% note.body.lines(chomp: true).reject { |l| l.strip.empty? }.first(8).each do |line| %>
            <% if line.match?(/^\s*- \[x\]/i) %>
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-amber-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="line-through text-gray-400 truncate"><%= line.sub(/^\s*- \[x\]\s*/i, "") %></span>
              </div>
            <% elsif line.match?(/^\s*- \[ \]/) %>
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="2"/></svg>
                <span class="truncate"><%= line.sub(/^\s*- \[ \]\s*/, "") %></span>
              </div>
            <% else %>
              <div class="truncate"><%= line %></div>
            <% end %>
          <% end %>
        </div>
      <% else %>
      <div class="text-gray-600 text-xs leading-relaxed line-clamp-8 prose prose-sm prose-gray max-w-none
                  prose-p:my-1 prose-ul:my-1 prose-ol:my-1 prose-li:my-0
                  prose-headings:text-xs prose-headings:font-semibold prose-headings:my-1
                  prose-pre:text-xs prose-pre:my-1 prose-code:text-xs
                  prose-blockquote:my-1 prose-blockquote:text-xs">
        <%= render_markdown(truncate(note.body, length: 500, omission: "…")) %>
      </div>
      <% end %>
    <% end %>
  </div>

  <% if note.tags.any? %>
    <div class="px-4 pb-2 flex flex-wrap gap-1.5">
      <% note.tags.limit(4).each do |tag| %>
        <span class="inline-block px-2 py-0.5 text-xs rounded-full font-medium" style="background-color: <%= tag.color %>18; color: <%= tag.color %>"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>

  <div class="px-4 pb-3 flex items-center justify-between">
    <span class="text-gray-400 text-xs"><%= time_ago_in_words(note.updated_at) %> ago</span>
    <div class="flex items-center space-x-2">
      <% if note.pinned? %>
        <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
      <% end %>
      <% if note.checklist? %>
        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      <% end %>
      <% if note.attachments.any? %>
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
      <% end %>
      <% if note.user != current_user %>
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" title="Shared by <%= note.user.name %>"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      <% end %>
    </div>
  </div>
<% end %>
