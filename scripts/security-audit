#!/usr/bin/env bash
set -euo pipefail

# Security audit and update script for the Notes application.
# Checks Ruby gems (bundler-audit) and Node packages (npm audit),
# then attempts to update any vulnerable dependencies.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAILURES=0

info()  { printf "${GREEN}[INFO]${NC}  %s\n" "$1"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$1"; }
error() { printf "${RED}[FAIL]${NC}  %s\n" "$1"; }

# ── Ruby gems (web/) ────────────────────────────────────────────────
audit_ruby() {
  local web_dir="$ROOT_DIR/web"
  if [[ ! -f "$web_dir/Gemfile.lock" ]]; then
    warn "No Gemfile.lock found in web/ — skipping Ruby audit"
    return
  fi

  info "Updating ruby-advisory-db and auditing gems …"
  cd "$web_dir"

  if ! bundle exec bundler-audit check --update; then
    warn "Vulnerabilities found — attempting bundle update of affected gems …"

    # Extract vulnerable gem names from bundler-audit output
    local gems
    gems=$(bundle exec bundler-audit check 2>&1 \
      | grep '^Name:' \
      | awk '{print $2}' \
      | sort -u)

    if [[ -z "$gems" ]]; then
      error "Could not determine which gems to update"
      FAILURES=$((FAILURES + 1))
      return
    fi

    # shellcheck disable=SC2086
    bundle update $gems

    info "Re-running audit after update …"
    if bundle exec bundler-audit check; then
      info "All Ruby vulnerabilities resolved"
    else
      error "Some Ruby vulnerabilities remain — manual intervention required"
      FAILURES=$((FAILURES + 1))
    fi
  else
    info "No Ruby vulnerabilities found"
  fi
}

# ── Node packages (mcp/) ───────────────────────────────────────────
audit_node() {
  local mcp_dir="$ROOT_DIR/mcp"
  if [[ ! -f "$mcp_dir/package.json" ]]; then
    warn "No package.json found in mcp/ — skipping Node audit"
    return
  fi

  info "Auditing Node packages …"
  cd "$mcp_dir"

  if ! npm audit --omit=dev 2>&1 | grep -q "found 0 vulnerabilities"; then
    warn "Vulnerabilities found — running npm audit fix …"
    npm audit fix
    info "Re-running audit after fix …"
    if npm audit --omit=dev 2>&1 | grep -q "found 0 vulnerabilities"; then
      info "All Node vulnerabilities resolved"
    else
      error "Some Node vulnerabilities remain — manual intervention required"
      FAILURES=$((FAILURES + 1))
    fi
  else
    info "No Node vulnerabilities found"
  fi
}

# ── Run tests ───────────────────────────────────────────────────────
run_tests() {
  local web_dir="$ROOT_DIR/web"
  if [[ ! -f "$web_dir/Gemfile.lock" ]]; then
    return
  fi

  info "Running test suite to verify nothing is broken …"
  cd "$web_dir"
  if bundle exec rspec --format progress; then
    info "All tests pass"
  else
    error "Tests failed after dependency updates"
    FAILURES=$((FAILURES + 1))
  fi
}

# ── Main ────────────────────────────────────────────────────────────
main() {
  info "Starting security audit"
  audit_ruby
  audit_node
  run_tests

  echo ""
  if [[ $FAILURES -gt 0 ]]; then
    error "$FAILURES check(s) failed — review output above"
    exit 1
  else
    info "Security audit complete — no issues"
  fi
}

main "$@"
